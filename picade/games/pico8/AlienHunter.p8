--tab 2: bullets
function init_bullets()
	bullets = {}
end
function shoot_bullet(spd)
	bullet = {
		x = player.x + 10,
		y = player.y + 2,
		w = 8,
		h = 8,
		sprite = 57,
		spd = spd,
		anim = {57, 58, 59, 16},
		frame = 1,
		pierce = false
	}
	add(bullets, bullet)
end
function shoot_charge_bullet(spd)
	bullet = {
		x = player.x + 10,
		y = player.y + 2,
		w = 16,
		h = 16,
		sprite = 72,
		spd = spd,
		anim = {72},
		frame = 1,
		pierce = false
	}
	add(bullets, bullet)
end
function shoot_beam()
	for i = 0, 4 do
		bullet = {
			x = player.x + 10 + i*8,
			y = player.y + 2,
			w = 8,
			h = 8,
			sprite = 71,
			spd = 10,
			anim = {71},
			frame = 1,
			pierce = true
		}
		add(bullets, bullet)
	end
end
function update_bullets()
	for bullet in all(bullets) do
		bullet.x += bullet.spd
		if bullet.x > 128 then
			del(bullets, bullet)
		end
	end
end
function draw_bullets()
	for bullet in all(bullets) do
		anim_obj(bullet, .1)
		spr(
			bullet.sprite,
			bullet.x,
			bullet.y,
			bullet.w/8,
			bullet.h/8
		)
	end
end
function anim_obj(obj, spd)
	obj.frame += spd
	if obj.frame > #obj.anim then
		obj.frame = 1
	end
	obj.sprite = 
	obj.anim[flr(obj.frame)]
end

function collide_bullet(enemy)
 for bullet in all(bullets) do
 	if collide(bullet, enemy) then
 	  enemy.health -= 1
 	  spawn_hitvfx(enemy.x - 5.5,
 	   enemy.y + 5)
 	  enemy.sprite = enemy.flashspr
 	  if not bullet.pierce then
 	  	del(bullets, bullet)
 	  end
 	  sfx(0)
 		if enemy.health < 0 then
 	 	sfx(2)
 	 	del(enemies, enemy)
 	 	player.score += 10
 	 	spawn_explosion(enemy.x,
 	  enemy.y)
 	  bg_spd += .05
			end
		end
 end
end
-->8
--tab 3: bg + vfx
function init_bg()
	bg_spd = 1
	bg_scroll = 0
end

function update_bg()
	bg_scroll += bg_spd
	if bg_scroll > 128 then
	 bg_scroll = 0
	end
	if bg_spd >= 3 then
		bg_spd = 3.5
	end
end


function draw_bg()
 for x = -8, 8 do
  for y = 0, 8 do
   spr(64, x*32 - bg_scroll, y*32,
    4, 4)
  end
 end
end



function init_vfx()
 vfxs = {}
end

function spawn_explosion(x, y)
	spawn_vfx(x, y, 8, 8,
	 {7,23, 8, 24, 25, 9}, 10)
end

function spawn_vfx(x, y, w, h,
anim, length)
 vfx = {
 x = x,
 y = y,
 w = w,
 h = h,
 anim = anim,
 length = length,
 sprite = 9,
 frame = 1
 
 }
 add(vfxs, vfx)
end
function update_vfx()
	for vfx in all(vfxs) do
	 anim_obj(vfx, .5)
	 vfx.length -= 1
	 if vfx.length < 0 then
		del(vfxs, vfx)
	 end
 end
end

function draw_vfx()
	for vfx in all(vfxs) do
		spr(
		 vfx.sprite,
			vfx.x,
			vfx.y,
			vfx.w/8,
			vfx.h/8
			)
	end
end


function spawn_hitvfx(x, y)
	spawn_vfx(x, y, 8, 8,{10}, 3)
end
-->8
--tab 4:enemy

function init_enemies()
 enemies = {}
 wave_timer = 0
 wave_cd = 140
end

function spawn_wave()
 local wave = flr(rnd(7))
 for e = 0, wave do
  local rndtype = flr(rnd(4))
  spawn_enemy(129,
  e*128/wave, rndtype)
 end
end

function spawn_enemy(x, y, etype)
 enemy = {
  x = x, 
  y = y,
  etype = etype,
  spd = .9,
  w = 16,
  h = 16,
  sprite = 33,
  anim = {33, 35, 37,16},
  frame = 1,
  health = 2,
  flashspr = 39,
  score = 10
 }
--tanky enemy
 if etype == 1 then
 	enemy.health = 7
 	enemy.spd = .3
 	enemy.score = 20
 end
--speedy enemy
 if etype == 2 then
 	enemy.health = 0
 	enemy.spd = 1.5
 	enemy.score = 5
 end
 add(enemies, enemy)
end


function hit_player(enemy)
	if collide(enemy, player) and
	 player.inv_timer < 0 then
		player.health -= 1
		player.inv_timer =
		player.inv_cooldown
		sfx(5)
		if player.health < 0 then
			state = "gameover"
			sfx(3)
		end
 end
end


function update_enemies()
 update_wave()
	for enemy in all(enemies) do
	 anim_obj(enemy, .1)
  enemy.x -= enemy.spd
  hit_player(enemy)
  collide_bullet(enemy)
  if enemy.x < -16 then
  	 del(enemies, enemy)
  end
 end
end

function collide_bullet(enemy)
 for bullet in all(bullets) do
 	if collide(bullet, enemy) then
 	  enemy.health -= 1
 	  spawn_hitvfx(enemy.x - 5.5,
 	   enemy.y + 5)
 	  enemy.sprite = enemy.flashspr
 	  del(bullets, bullet)
 	  sfx(0)
 		if enemy.health < 0 then
 	 	sfx(2)
 	 	del(enemies, enemy)
 	 	player.score += enemy.score
 	 	spawn_explosion(enemy.x,
 	  enemy.y)
 	  bg_spd += .05
			end
		end
 end
end


function update_wave()
	wave_timer -= 1
 if wave_timer < 0 then
 	wave_timer = wave_cd
 	spawn_wave()
 end
end

function draw_enemies()
	for enemy in all(enemies) do
	 if enemy.etype == 1 then
		 pal(11, 14)
		 pal(3, 8)
	 end
	 if etype == 2 then
	  pal(3, 9)
	  pal(11, 10)
  end
		spr(
		 enemy.sprite,
			enemy.x,
			enemy.y,
			enemy.w/8,
			enemy.h/8
			)
			pal()
	end
end


function collide(a, b)
	if a.x < b.x + b.w and
	a.x + a.w > b.x and
	a. y < b.y + b.h and
	a. y + a.h > b.y then
	 return true
	end
end
