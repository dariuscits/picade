pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--tab 0: main
function start_game()
 state = "game"
 player_init()
 init_bullets()
 init_bg()
 init_enemies()
 init_vfx()
end
function update_game()
	player_update()
 update_bullets()
 update_bg()
 update_enemies()
 update_vfx()
end
function draw_game()
	cls()
 draw_bg()
 player_draw()
 draw_bullets()
 draw_enemies()
 draw_vfx()
 draw_player_ui()
end
function _init()
 state = "title"
end
function _update()
 if state == "game" then
 	update_game()
 end
end
function _draw()
 if state == "game" then
 	draw_game()
 end
 if state == "gameover" then
 	draw_gameover()
 end
 if state == "title" then
 	draw_title()
 end
end
-->8
-- tab 1: player
function player_init()
	player = {
		x = 0,
		y = 54,
		w = 16,
		h = 16,
		sprite = 12,
		spd = 2.3,
		basespd = 2.3,
		slowspd = 1,
		cooldown = 10,
		cooldowntime = 0,
		frame = 1,
		anim = {1, 3,16},
		flash = 0,
		score = 0,
		health = 3,
		maxhealth = 3,
		inv_timer = 0,
		inv_cooldown = 30,
		charge = false,
		chargetime = 0,
		beamtime = 20,
		combotime = 0,
		charge_cooldown = 35,
		charge_cooldowntime = 0,
		ammo = 20,
		max_ammo = 20,
		reloadtime = 0,
		reload_cd = 30
	}
end
function move_player()
	if btn(⬅️) then
		player.x -= player.spd
	end
	
	if btn(➡️) then
		player.x += player.spd
	end
	if btn(⬆️) then
		player.y -= player.spd
	end
	
	if btn(⬇️) then
		player.y += player.spd
	end
end
function collide_player()
	if player.x < 0 then
		player.x = 0
	end
	
	if player.x > 128 - player.w then
		player.x = 128 - player.w	
	end
	
	if player.y < 0 then
		player.y = 0
	end
 
	if player.y > 128 - player.h then
		player.y = 128 - player.h
	end
end
function shoot_player()
	player.cooldowntime -= 1
	player.flash -= 1
	player.charge_cooldowntime -= 1
	
	if player.reloadtime > 0 then
		player.reloadtime -= 1
		if player.reloadtime < 1 then
			player.ammo = player.max_ammo
		end
	end
	
	
	if btn(4) and btn(5) then
		player.combotime += 1
		player.spd = player.slowspd
		player.charge = false
		player.chargetime = 0
	else
		player.spd = player.basespd
		if player.combotime > 0 then
			if player.combotime >=
			player.beamtime and
			player.charge_cooldowntime < 1 and
			player.reloadtime < 1 and
			player.ammo >= 4 then
				player.ammo -= 4
				shoot_beam(spd)
				player.charge_cooldowntime = player.charge_cooldown
				sfx(1)
				if player.ammo < 1 then
					player.reloadtime = player.reload_cd
				end
			elseif player.cooldowntime < 1 then
				player.cooldowntime = player.cooldown
				player_fire()
			end
			player.combotime = 0
		end
		
		if btn(4) then
			player.charge = true
			player.chargetime += 1
		elseif player.charge then
			if player.charge_cooldowntime < 1 and
			player.reloadtime < 1 and
			player.ammo >= 1 then
				player.ammo -= 1
				shoot_charge_bullet(7)
				player.charge_cooldowntime =
			 player.charge_cooldown
				sfx(1)
				if player.ammo < 1 then
					player.reloadtime =
					 player.reload_cd
				end
			end
			player.charge = false
			player.chargetime = 0
		end
		
		if btn(5) and
		player.cooldowntime < 1 and
		player.reloadtime < 1 and
		player.ammo > 0 then
			player.cooldowntime = player.cooldown
			player.flash = 2
			player.ammo -= 1
			sfx(1)
			shoot_bullet(7)
			if player.ammo < 1 then
				player.reloadtime =
				 player.reload_cd
			end
		end
	end
end
function player_fire()
	player.flash = 3
	shoot_bullet(7)
	bullets[#bullets].y -= 6
	shoot_bullet(7)
	shoot_bullet(7)
	bullets[#bullets].y += 6
end
function player_update()
 player.inv_timer -= 1
	anim_obj(player, .1)
	shoot_player()
	move_player()
	collide_player()
end
function player_draw()
 if player.inv_timer < 0 or
 player.inv_timer % 3 == 0 then	
	spr(
		player.sprite,
		player.x,
		player.y,
		player.w/8,
		player.h/8
	)
	end
	circfill(player.x + 14, 
	player.y + 6, player.flash, 10)
end
function draw_player_ui()
 print("score: "..player.score,
	 54, 2, 7)
	 
	for i = 0, player.maxhealth-1 do
	 if i < player.health then
	 	spr(11, i*10, 0, 1, 1)
	 else
	  spr(12, i*10, 0, 1, 1)
	 end
 end
 if player.reloadtime > 0 then
 	print("reloading", 2, 122, 8)
 else
 	print("ammo: "..player.ammo, 2, 122, 7)
 end
 score_level()
end
  
function score_level()
	if player.score >= 100 then
		print("score: "..player.score,
	 54, 2, 4)
	 if player.score >= 250 then
		 print("score: "..player.score,
	  54, 2, 6)
	  if player.score >= 500 then
	  	print("score: "..player.score,
	   54, 2, 10)
   end
	 end
	end
end
