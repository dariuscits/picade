-- tab 5: game over and title

function draw_gameover()
	cls(8)
	print("you died!", 30, 40, 0)
	print("press x to restart", 30,
	60, 0)
	if btn(5) then
		state = "title"
	end
end

function draw_title()
 cls(12)
 print("alien hunter", 20, 30, 7)
 print("press z to restart", 20,
 40, 7)
 print("x: normal attack",
  20, 50, 7)
 print("z: charge attack",
  20, 60, 7)
 print("z+x: triple attack",
  20, 70, 7)
 print("hold 3s x+z: beam attack",
  20, 80, 7)
 if btn(4) then
 	start_game()
 end	
end

