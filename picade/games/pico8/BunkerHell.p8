		gun.gun_y = player_body.y+8
	end
	if gun.gun_frames == 9 then
		gun.gun_x = player_body.x+2
		gun.gun_y = player_body.y+8
	end
	if btnp(5) and player_body.cd_timer < 0 and player_body.ammo > 0 then
		player_body.cd_timer = player_body.cooldown 
		sfx(0)
		player_body.ammo -= 1
		shoot_bullets()
	end
	move_bullet()
	if btn(4) and btn(2) and player_body.ammo < 10 then
		player_body.ammo_timer -= 1
		if player_body.ammo_timer < 0 then
		player_body.ammo= 10
		sfx(5)
		player_body.ammo_timer = player_body.ammo_cooldown
	end
end


