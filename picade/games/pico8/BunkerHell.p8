pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--core--

state= "title"

function _init()
	init_bullets()
	player_init()
	init_bunker()
	init_enemies()
	init_gore()
end

function start_game()
	state = "game"
	init_bullets()
	player_init()
	init_bunker()
	init_enemies()
	init_gore()
end

function _draw()
cls()
	if state == "game" then
		cls(3)
		draw_game()
	end
	if state == "title" then
		cls(0)
		draw_title()
	end
	if state == "gameover" then
		cls(8)
		draw_gameover()
	end
end

function draw_game()
	draw_bunker()
	draw_gore()
	draw_enemies()
	draw_bullets()
	draw_player()
	draw_player_ui()
end

function _update()
	if state == "game" then
		update_game()
	end
end

function update_game()
	update_player()
	update_bullets()
	update_enemies()
	update_gore()
end
