--title screen & game over--

function draw_title()
	print("\^w\^tbunker hell",22,20,7)
	print("press z to start",32,50,7)
	print("controls:",2,84,7)
	print("⬅️➡️⬆️⬇️ = move + gun aim",2,90,7)
	print("z = lock move",2,96,7)
	print("hold z+⬆️ = reload",2,102,7)
	print("❎ = shoot",2,108,7)
	if btnp(4) then
		start_game()
	end
end

function draw_gameover()
	print("\^w\^tyou died",34,20,7)
	print("press z to restart",30,50,7)
	if btnp(4) then
		start_game()
	end
end
