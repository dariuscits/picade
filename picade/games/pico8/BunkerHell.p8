	if btn(3) then
		if player_body.frames == 18 or player_body.frames == 2 then
			player_body.frames = 34
			gun.gun_frames = 8
		end
		if player_body.frames == 19 or player_body.frames == 3  then
			player_body.frames = 35
			gun.gun_frames = 9
		end
		if btn(3) and not btn(4) then
			player_body.y += 1
		end
	end
	if gun.gun_frames == 4 then
		gun.gun_x = player_body.x-7
		gun.gun_y = player_body.y
	end
	if gun.gun_frames == 5 then
		gun.gun_x = player_body.x+8
		gun.gun_y = player_body.y
