--player--

function player_init()
	player_body = {
	frames= 2,
	x= 60,
	y= 60,
	cd_timer= 0,
	cooldown= 10,
	health= 5,
	max_health= 5,
	inv_timer= 0,
	invuln= 30,
	kills= 0,
	ammo= 10,
	ammo_timer= 20,
	ammo_cooldown= 20
	}
	gun = {
	gun_frames= 4,
	gun_x= 90,
	gun_y= 90
	}
end

function draw_player()
	if player_body.inv_timer % 4 == 0 or player_body.inv_timer < 0 then
		spr(player_body.frames,player_body.x,player_body.y)
	end
	spr(gun.gun_frames,gun.gun_x,gun.gun_y)
	spr(50,0,0)
end

function draw_player_ui()
	for i=0, player_body.max_health-1 do
		if i < player_body.health then
			spr(51,6+i*3,0)
		else
			spr(52,6+i*3,0)
		end
	end
end

function update_player()
	player_body.cd_timer -= 1
	if player_body.health < 1 then
		state= "gameover"
	end
	if player_body.x < -2 then
		player_body.x = -2
	end
	if player_body.x > 121 then
		player_body.x = 121
	end
	if player_body.y < -2 then
		player_body.y = -2
	end
	if player_body.y > 121 then
		player_body.y = 121
	end
	if btn(0) then
		player_body.frames= 2
		gun.gun_frames= 4
		if btn(0) and not btn(4) then
	 	player_body.x -= 1
		end
	end
	if btn(1) then
		player_body.frames= 3
		gun.gun_frames= 5
			if btn(1) and not btn(4) then
				player_body.x += 1
			end
	end
	if btn(2) then
		if player_body.frames == 2 or player_body.frames == 34 then
			player_body.frames = 18
			gun.gun_frames = 6
		end
		if player_body.frames == 3 or player_body.frames == 35 then
			player_body.frames = 19
			gun.gun_frames = 7
		end
		if btn(2) and not btn(4) then
			player_body.y -= 1
		end
