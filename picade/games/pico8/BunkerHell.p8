--gore--

function init_gore()
	vfxs={}
end

function spawn_explosion(x,y)
	local anim = {20,21,22,23,24,25,36,37}
	spawn_gore(x,y,8,8,anim,10)
end

function spawn_gore(x,y,w,h,anim,length)
	vfx = {
	x= x,
	y= y,
	w= w,
	h= h,
	anim= anim,
	length= length,
	sprite= 20,
	frame= 2
	}
	add(vfxs,vfx)
end

function draw_gore()
	for vfx in all(vfxs) do
		spr(vfx.sprite,vfx.x,vfx.y,vfx.w/8,vfx.h/8)
	end
end

function update_gore()
	for vfx in all(vfxs) do
		animate_obj(vfx,0.5)
		vfx.length -= 1
		if vfx.length < 0 then
			del(vfxs,vfx)
		end
	end
end
