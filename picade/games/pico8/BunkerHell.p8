--enemies--

function init_enemies()
	enemies = {}
	spawn_wave()
	hit_cooldown = 5
	enemy_count = 4
	wave_count= 1
	wave_countx= -30
	wave_count_timer= 0
	wave_count_cooldown= 40
end

function spawn_wave()
	spawn_enemy(10,61,-9,8,8)
	spawn_enemy(11,-9,60,8,8)
	spawn_enemy(26,61,128,8,8)
	spawn_enemy(42,130,60,8,8)
end

function spawn_enemy(sprite,x,y,w,h,etype)
	enemy = {
	etype = etype,
	x = x,
	y = y,
	w = w,
	h = w,
	spd = 0.1,
	sprite = sprite,
	anim= 0,
	frame=	0,
	health= 3,
	damage= 1,
	dx= 0,
	dy= 0,
	hit_timer= 0
	}
	enemy.etype = 0
	if enemy.etype == 0 then
		enemy.spd= 0.1
		enemy.health= 3
		enemy.damage = 1
	end
	if enemy.etype == 1 then
		enemy.spd= 0.2
		enemy.health= 2
		enemy.damage = 1
	end
	add (enemies,enemy)
	
end

function draw_enemies()
	print("wave " ..wave_count,wave_countx,61,7)
	print("kills:" ..player_body.kills,95,1,2)
		for enemy in all(enemies) do
		if enemy.hit_timer > 0 then
			for i=0, 16 do
				pal(i,7)
			end
		end
		spr(enemy.sprite,enemy.x,enemy.y,enemy.w/8,enemy.h/8)
		pal()
	end
end

function update_enemies()
	player_body.inv_timer -= 1
	wave_count_timer -= 1
	collide_bullet(enemies)
	if enemy_count == 0 then
		spawn_wave()
		enemy_count = 4
		health = 3
		wave_count += 1
		wave_countx = 53
		wave_count_timer = wave_count_cooldown
	end
	if wave_count_timer < 0 then
		wave_countx = -30
	end
	for enemy in all(enemies) do
		enemy.hit_timer -= 1
		if collide(player_body.x,player_body.y,8,8,enemy.x,enemy.y,enemy.w/3,enemy.h/3) and player_body.inv_timer < 0 then
			player_body.inv_timer = player_body.invuln
			player_body.health -= enemy.damage
			if player_body.health > 0 then
				sfx(3)
			else
				sfx(4)
			end
		end
	for enemy in all(enemies) do
		if enemy.hit_timer < 0 then
			chase_player(enemy)
			enemy.x += enemy.dx*enemy.spd
			enemy.y += enemy.dy*enemy.spd
 	end
 	look_enemy(enemy)
		end
		if collide(enemy.x,enemy.y,1,1,24,21,1,30)
