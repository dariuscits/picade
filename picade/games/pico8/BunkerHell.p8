function chase_player(enemy)
	enemy.dx = 0
	enemy.dy = 0
	local dx = player_body.x - enemy.x
	local dy = player_body.y - enemy.y
	local dist = dx*dx + dy*dy
	local mindist = 110*110
	if dist < mindist then
		enemy.dx = mid (-1,dx,1)
		enemy.dy	= mid (-1,dy,1)
		end
end

function look_enemy(enemy)
	if	enemy.dx < 0 and enemy.etype	== 0 then
		enemy.sprite = 10
	elseif	enemy.dx > 0 and enemy.etype	== 0 then
		enemy.sprite = 11
	end
	if enemy.dy < 0 and enemy.dx < 0 and enemy.etype	== 0 then
		enemy.sprite = 26
	elseif	enemy.dy > 0 and enemy.dx < 0 and	enemy.etype == 0 then
		enemy.sprite = 42
	end
	if	enemy.dx < 0 and enemy.etype	== 1 then
		enemy.sprite = 58
	elseif	enemy.dx > 0 and enemy.etype	== 1 then
		enemy.sprite = 59
	end
	if enemy.dy < 0 and enemy.dx < 1 and enemy.etype	== 1 then
		enemy.sprite = 74
	elseif	enemy.dy > 0 and enemy.dx < 1 and	enemy.etype == 1 then
		enemy.sprite = 90
	end
end

function collide_bullet(enemies)
for enemy in all(enemies) do
		for bullet in all(bullets) do
			if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/3,bullet.h/2,enemy.x,enemy.y,enemy.w,enemy.h)
			then
			enemy.health -= 1
			sfx(1)
			del(bullets,bullet)
			enemy.hit_timer = hit_cooldown
				if enemy.health < 1 then
					spawn_explosion(enemy.x,enemy.y)
					del(enemies,enemy)
					enemy_count -= 1
					player_body.kills += 1
					sfx(2)
				end
			end
		end
	end
end
