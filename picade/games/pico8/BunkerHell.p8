--bullets--

function init_bullets()
	bullets = {}
end

function shoot_bullets()
	bullet = {
	bullet_frames= 0,
	bullet_x= player_body.x,
	bullet_y= player_body.y,
	spd= 4,
	w= 8,
	h= 8
	}
	add(bullets,bullet)
end

function draw_bullets()
	for bullet in all(bullets) do
		spr(bullet.bullet_frames,
		bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8)
	end
end

function update_bullets()
		if btnp(5) and bullet.bullet_frames == 0 then
			if gun.gun_frames == 4 and bullet.bullet_frames == 0 then
				bullet.bullet_frames = 49
				bullet.bullet_x= gun.gun_x
				bullet.bullet_y= gun.gun_y-1
			end
			if gun.gun_frames == 5 then
				bullet.bullet_frames = 33
				bullet.bullet_x= gun.gun_x
				bullet.bullet_y= gun.gun_y-1
			end
			if gun.gun_frames == 6 then
				bullet.bullet_frames = 17
				bullet.bullet_x= gun.gun_x-1
				bullet.bullet_y= gun.gun_y
			end
			if gun.gun_frames == 7 then
				bullet.bullet_frames = 17
				bullet.bullet_x= gun.gun_x+1
				bullet.bullet_y= gun.gun_y
			end
			if gun.gun_frames == 8 then
				bullet.bullet_frames = 1
				bullet.bullet_x= gun.gun_x-1
				bullet.bullet_y= gun.gun_y
			end
			if gun.gun_frames == 9 then
				bullet.bullet_frames = 1
				bullet.bullet_x= gun.gun_x+1
				bullet.bullet_y= gun.gun_y
			end
	end
end
-->8
--bullet movement--

function move_bullet()
	for bullet in all(bullets) do
		if bullet.bullet_frames == 33 then
			bullet.bullet_x += bullet.spd
		end
		if bullet.bullet_frames == 17 then
			bullet.bullet_y -= bullet.spd
		end
		if bullet.bullet_frames == 1 then
			bullet.bullet_y += bullet.spd
		end
		if bullet.bullet_frames == 49 then
			bullet.bullet_x -= bullet.spd
		end
		if bullet.bullet_x < -8 or bullet.bullet_x > 128 or bullet.bullet_y < -8 or bullet.bullet_y > 128 then
			del(bullets,bullet)
		end
	
		if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,21,21,4,30)
	then
		del(bullets,bullet)		
	end	
	if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,21,21,33,4)
	then
		del(bullets,bullet)
	end
	
	if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,97,21,4,30)
	then
		del(bullets,bullet)	
	end
	if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,71,21,28,4)
	then
		del(bullets,bullet)	
	end
	
	if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,97,70,4,30)
	then
		del(bullets,bullet)	
	end
	if collide(bullet.bullet_x,bullet.bullet_y,bullet.w/8,bullet.h/8,71,95,28,4)
	then
		del(bullets,bullet)	
	end
		
	if collide(bullet.bullet_x,bullet.bullet_y,1,1,21,70,4,30)
	then
		del(bullets,bullet)	
	end
	if collide(bullet.bullet_x,bullet.bullet_y,1,1,21,96,28,4)
	then
		del(bullets,bullet)	
	end
end
end
