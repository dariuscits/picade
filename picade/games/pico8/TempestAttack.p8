pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 state = "title"
end

function start_game()
 state = "game"
 score=0
	bgscroll = 0
	--player variables
	plyr = {}
	plyr.x=64
	plyr.y=100
	plyr.spd=2
	plyr.spr=23
	invuln=1
	--enemies
	enemies={}
	spawn_enemy(64,10)
	spawntimer = 130
	--projectile variables
	prj_spd=4
	prj_x=64
	prj_y=64
	prj_spr=6
	prj_list={}
	--animation
	flash=0
	--ui
	f_hrt=11
	e_hrt=12
	hrts=3
	dmg=1
end

function _update()
 if state == "game" then
  update_game()
 end
 if state == "title" then
  update_title()
 end
 if state == "gameover" then
 update_gameover()
 end
end


function update_game()
--player sprite movement
 plyr.spr=23
	if btn(⬅️) then
		plyr.x-=plyr.spd
	 plyr.spr=1
	end
	if btn(➡️) then
	 plyr.x+=plyr.spd
	 plyr.spr=25
	end
	if btn(⬇️) then
		plyr.y+=plyr.spd
	end
	if btn(⬆️) then
		plyr.y-=plyr.spd
	end 
	if plyr.x > 120 then
		plyr.x=120
	end
	if plyr.x < 0 then
	 plyr.x=0
	end
	if plyr.y < 0 then
		plyr.y=0
	end
	--projectile animation
	if btnp(🅾️) then
		spawn_projectile()
	 sfx(0)
	 flash=5
	end
	--enemies
	move_enemies()
	--projectile movement
	projectile_movement()
	 prj_y-=prj_spd
	 flash=flash-1
	 invuln-=1
	 prj_spr=prj_spr+1
	if prj_spr > 9 then
	 prj_spr = 6
	end
end

function _draw()
 if state == "game" then
  draw_game()
 end
 if state == "title" then 
 draw_title()
 end
 if state == "gameover" then
 	draw_gameover()
 end
end

function draw_game()
--clear screen
 cls(3)
--background
 bg()
--draw sprites
	draw_projectiles()
	draw_enemies()
	draw_player()
	--ui
	draw_ui()
	end

function draw_ui()
	--ui
	for i=1,hrts do
		if dmg > i then 
			spr(e_hrt,i*9,115)
		else
		 spr(f_hrt,i*9,115)
		end
	end 
	print("score: "..score,40,116,7)
end

function draw_player()
--flicker player opacity if invul
		if invuln < 0 or
	invuln % 2 == 0 then
		spr(plyr.spr,
		plyr.x,plyr.y)
			circfill
	(plyr.x+3,plyr.y-2,flash,12)
	end
end

function bg()--background
	bgscroll=bgscroll+1
	if bgscroll > 128 then
		bgscroll = 0
	end
	for x=0,8 do
		for y=-8,8 do
		 spr(16,x*16,y*16+bgscroll,2,2)
		end
 end
end

function col(a,b)
	local a_left = a.x
	local b_left = b.x
	local a_right = a.x+8
	local b_right = b.x+8
	local a_top = a.y
	local b_top = b.y
	local a_bottom = a.y+8
	local b_bottom = b.y+8
	
	if a_top < b_bottom and
	b_top < a_bottom and
	a_left < b_right and
	b_left < a_right then
		return true
	else
		return false
	end
end


-->8
--projectiles

function spawn_projectile()
	local prj = {}
	prj.x = plyr.x
	prj.y = plyr.y
	prj.spr = 6
	prj.spd = 4
	add(prj_list,prj)
end

function draw_projectiles()
 for prj in all(prj_list) do
  spr(prj.spr,prj.x,prj.y)
 end
end

function projectile_movement()
	for prj in all(prj_list) do
	 prj.y -= prj.spd
	 prj.spr += 1
	 if prj.spr > 10 then 
	 	prj.spr = 6
	 end
	end
end
-->8
--enemies

esprs={2,3,26}

function spawn_enemy(x,y)
 local enemy = {}
 enemy.x = x
 enemy.y = y
 local hp = flr(1+rnd(3))
 enemy.spr = esprs[hp]
 enemy.spd = 1+rnd(3)
 enemy.hp = hp
 add(enemies,enemy)
end

function spawn_wave()
 for i=0,8 do
  spawn_enemy(i*16,-8)
 end
end

function move_enemies()
 spawntimer += 1
 if spawntimer > 130 then
 	spawn_wave()
 	spawntimer = 0
 end
	for enemy in all(enemies) do
		if col(enemy,plyr)
		and invuln < 0 then
			dmg+=1
			invuln=30
			if dmg > 4 then
				state="gameover"
			end
		end
			enemy.y += enemy.spd
		for prj in
		all(prj_list) do
			if col(enemy,prj) then
				if enemy.hp > 0 then
					enemy.hp -= 1
				else
					del(enemies,enemy)
					score+=10
				end
				del(prj_list,prj)
			end
		end
end
end

function draw_enemies()
 for enemy in all(enemies) do
  spr(enemy.spr,enemy.x,enemy.y)
 end
end
-->8
--title and gameover

function draw_title()
 cls()
 cls(12)
	camera(0,0)
	print("\^w\^ttempest attack",10,50,0)
 print("press ❎ to start!",30,70,0)
end

function update_title()
 if btn(❎) then
  start_game()
 end
end

function draw_gameover()
	cls(8)
	print("tempest has fallen!"
	,35,30,0)
	print("press ❎ to try again"
	,30,110,12)
end

function update_gameover()
 if btn(❎) then
  start_game()
 end
end
