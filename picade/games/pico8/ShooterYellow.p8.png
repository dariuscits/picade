pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
music(0)
state = "title"

function _init()
end

function _update()
	if state == "game" then
		move_player()
		move_bullet()
		move_enemy()
	end
	
	if state == "gameover" then
		update_gameover()
	end
	if state ==  "title" then
		update_title()
	end
end

function _draw()

			if state == "game" then
				cls(0)
				draw_bg()
				draw_explosion()
				draw_player()
				draw_bullet()
				draw_enemy()
				draw_ui()
			end
			if state == "gameover" then
				draw_gameover()
			end
			if state ==  "title" then
				draw_title()
			end				
end

function start_game()

score = 0

state = "game"

enemies = {}
bullets = {}

player = {}

player.x = 64
player.y = 64
player.spd = 3
player.spr = 0

lives = 3
maxlives = 4
invuln  = 0 
trail_spr = 3

end

function col(a,b)

 local a_left = a.x
 local a_right = a.x+8
 local a_top = a.y
 local a_bottom = a.y+8
 
 local b_left = b.x
 local b_right = b.x+8
 local b_top = b.y
 local b_bottom = b.y+8
 
 if a_top > b_bottom then 
 	return false
 end
 if b_top > a_bottom then
 	return false
 end
 if a_left > b_right then
 	return false
 end
 if b_left > a_right then
 	return false
 end
 
 return true
 
end

-->8
--player

player = {}



player.x = 64
player.y = 64
player.spd = 3
player.spr = 0

lives = 3
maxlives = 1
invuln  = 0 
trail_spr = 3
bullettimer = 0
function draw_player()
    trail_spr += 0.3
    if trail_spr > 8  then
     trail_spr = 3
    end
    
    if invuln % 2 == 0 then
    	spr(trail_spr, player.x,player.y+6)
      
     
    	spr(player.spr, player.x,player.y)
    end
    
				
end

function move_player()
    
    if invuln > 0 then
    	invuln -= 1
    end
    
    if bullettimer > 0 then
    	bullettimer -= 1
    end

				player.spr = 0
				
				if btn(0) then
								player.x -= player.spd
								player.spr = 1
				end
				if btn(1) then
								player.x += player.spd
								player.spr = 2
				end
				if btn(2) then
								player.y -= player.spd
				end
				if btn(3) then
								player.y += player.spd				
				end
				if btn(4) then
					if bullettimer < 1 then
								spawn_bullet()
								sfx(0)
								bullettimer = 5
								sfx(6)
								
					end
				end
				
end
-->8
--bullet


bullets = {}


function spawn_bullet()
	
	local bullet = {}
	bullet.x = player.x
	bullet.y = player.y
	bullet.spd = 5
	bullet.spr = 3
	
	add(bullets,bullet)
end
function move_bullet()

	for bullet in all(bullets) do
		bullet.y -= bullet.spd
			if bullet.y < - 8 then
				del(bullets,bullet)
			end
	end
	
end 
function draw_bullet()
	
	for bullet in all(bullets) do
	
		bullet.spr += 4
		
		if bullet.spr >12 then
			bullet.spr = 9
		end
		
		spr(bullet.spr,bullet.x
		,bullet.y)
	end
	
		
end
-->8
--enemy

enemies = {}

enemy_timer = 0

function spawn_enemy(etype,x,y)

	local enemy = {}
	enemy.x = x
	enemy.y = y
	enemy.etype = etype
	enemy.shoottimer = 0
 enemy.spr = 19
 enemy.firstspr = 19
 enemy.lastspr = 25
 enemy.points = rnd(3)
 --basic enemy 	
	if etype ==  0 then
		enemy.hp = 1
		enemy.spd = 2
		enemy.spr = 19
		enemy.firstspr = 19
		enemy.lastspr = 25
		enemy.points = rnd(15)
	end
	
	--shooting enemy
	if etype == 1 then
		enemy.hp = 3
		enemy.spd = 1.5
		enemy.spr = 35
		enemy.firstspr = 35
		enemy.lastspr = 44
  enemy.points = rnd(20)
	end
		
		--chaser enemy
		if etype == 2 then
			enemy.hp = 3
			enemy.spd = 2
			enemy.spr = 48
			enemy.firstspr = 48
			enemy.lastspr = 5
			enemy.points = rnd(25)
	end
			--bullet 
		if etype == 3 then
			enemy.hp = 1+rnd(3)
			enemy.spd = 1+rnd(2)
			enemy.spr = 57
			enemy.firstspr = 57
			enemy.lastspr = 62
	end
	add(enemies,enemy)
	
end

function move_enemy()

	enemy_timer += 5
	
	if enemy_timer > 130 then
		local etype = flr(rnd(3))
		local x = rnd(120)
		local y = -8
		spawn_enemy(etype,x,y)
		enemy_timer = 0 end
	for enemy in all(enemies) do
	
		if enemy.etype ==  1 then
			
			enemy.shoottimer += 0.9
			if enemy.shoottimer > 40 then
				spawn_enemy(3,enemy.x,enemy.y)
				enemy.shoottimer = 0
			end
			
		end

	if col(enemy,player)
	and invuln < 1 then
		lives -= 1
		invuln = 120
		
		if lives < 0 then
			music(1) 
			state = "gameover"
		end
	end
		for bullet in all(bullets) do
				
			if enemy.etype == 2 then
				local dir = 
				(player.x - enemy.x)/10
				enemy.x += dir  
			end
			if col(enemy,bullet) then
				enemy.hp-=1
				if enemy.hp <= 0 then
					score += enemy.points
					spawn_explosion(enemy.x,enemy.y)
					
					del(enemies,enemy)
				end
				del(bullets,bullet)
			end
		end
		
	 enemy.y += enemy.spd
	 
	 if enemy.y > 128 then
	 	del(enemies,enemy)
	 
	
	end
end		
end

function draw_enemy()
	
	for enemy in all(enemies) do
	 
		enemy.spr += .2
		if enemy.spr > enemy.lastspr 
		then  enemy.spr = enemy.firstspr
		end
	
	 spr(enemy.spr,enemy.x,enemy.y)
	end
	
	
end
-->8
--ui

function draw_ui()

	for i = 1,3 do
		if i < lives + 1 then
			spr(26,i*9,5)
		else
			spr(27,i*9,5)
		end
	end
	 
	print(score,40,3)
	
		
end

bg_offset = 0
function draw_bg()
	bg_offset +=rnd(5)
	if bg_offset > 128 then
	
		bg_offset = 0
	
	end
	for x=1,128,16 do
	
		for y=-128,128,16 do
		
		spr(169,x,y+bg_offset,2,2)
		end
	
	end
end
-->8
--the effects

explosions = {}


function spawn_explosion(x,y)
	local explosion = {}
	explosion.spr = 30
	explosion.x = x
	explosion.y = y
	sfx(3)
	
	add(explosions,explosion)
end

function draw_explosion()
	for explosion in all(explosions) do
	 explosion.spr += .2
	 if explosion.spr > 33 then
	  del(explosions,explosion)
	 end
		spr(explosion.spr,
		explosion.x,explosion.y)
	end
end
-->8
--game over

hiscore = 0

function draw_gameover()
 cls(8)
 if score > hiscore then
 	hiscore = score
 end
 print('you died,loser take the l',
 20,60,0)
 print("your score was "..score,30,70,0)
	print("high score "..hiscore,
	30,50,0) 
end

function update_gameover()
	if btn(5) then
		start_game()
		state = "title"
	end
end

function draw_title()
	cls()
	map()
end

function update_title()
	if btnp(5) then
		start_game()
	end
end
